Subject: [PATCH 9/9] refactor(typography): migrate FlavorSearchPage

~12 replacements: section labels, gene names, compound titles,
gene detail header, full_name text. Eliminates font-medium.
---
 .../FlavorSearchPage/FlavorSearchPage.jsx        | 16 ++++++++--------
 1 file changed, 8 insertions(+), 8 deletions(-)

diff --git a/src/components/FlavorSearchPage/FlavorSearchPage.jsx b/src/components/FlavorSearchPage/FlavorSearchPage.jsx
index 7e3f69c..3c7cc63 100644
--- a/src/components/FlavorSearchPage/FlavorSearchPage.jsx
+++ b/src/components/FlavorSearchPage/FlavorSearchPage.jsx
@@ -54,7 +54,7 @@ export function FlavorSearchPage() {
             {/* Suggestions */}
             {!query && (
               <div className="mt-4">
-                <div className="text-[11px] text-slate-500 uppercase tracking-[1px] mb-2.5">Try searching for:</div>
+                <div className="type-label mb-2.5">Try searching for:</div>
                 <div className="flex flex-wrap gap-2">
                   {suggestedSearches.map(s => (
                     <button
@@ -134,15 +134,15 @@ export function FlavorSearchPage() {
                 <div className="flex items-center gap-3 mb-1.5">
                   <div className="text-[10px] text-slate-500 min-w-[20px]">#{idx + 1}</div>
                   <div className="flex items-baseline gap-2 flex-1">
